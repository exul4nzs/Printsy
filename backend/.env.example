DEBUG=True
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgresql://user:password@localhost:5432/customprint

# GCash Payment Info (shown to customers at checkout)
GCASH_NUMBER=0955 905 4871
GCASH_NAME=Your Name Here

# AWS S3 (optional - comment out to use local storage)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_STORAGE_BUCKET_NAME=your_bucket_name
# AWS_S3_REGION_NAME=us-east-1

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Telegram Bot Notifications (optional but recommended)
# 1. Message @BotFather to create a bot and get the token
# 2. Message @userinfobot to get your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here
TELEGRAM_NOTIFICATIONS_ENABLED=True
